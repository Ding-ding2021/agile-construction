// Prisma Schema for 多Agent建店管理平台
// V1 实体化模式 — 结构化实体表（已删除快照表 ProjectState/TaskState/AcceptanceState/SettlementState）
// Schema 唯一来源，local-api/store/schema.sql 已废弃

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── 审计日志表 ────────────────────────────────────────────────
model AuditLog {
  id          Int      @id @default(autoincrement())
  envId       String   @map("env_id")
  scene       String
  detail      String
  projectCode String?  @map("project_code")
  at          DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([envId])
  @@index([projectCode])
  @@index([scene])
  @@map("audit_logs")
}

// ─── 幂等记录表 ────────────────────────────────────────────────
model IdempotencyKey {
  key            String   @id
  scope          String
  envId          String   @map("env_id")
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   String?  @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at")
  expiredAt      DateTime @map("expired_at")

  @@index([envId])
  @@index([scope])
  @@index([expiredAt])
  @@map("idempotency_keys")
}

// ─── 项目实体表（V2 结构化数据）─────────────────────────────────
// 从 JSON 快照逐步迁移到结构化字段
model Project {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  brand     String
  status    String   // 旧版单状态字段（向后兼容）
  parentStatus  String  @default("启动") @map("parent_status")  // 新版父状态
  subStatusJson String? @map("sub_status_json")                 // JSON: SubStatusProgress
  statusTone String  @map("status_tone")
  stage     String
  progress  Int      @default(0)
  budget    String?
  teamSize  String?  @map("team_size")
  dateRange String?  @map("date_range")
  description String?
  owner     String?
  riskLevel String?  @map("risk_level")
  riskCount Int      @default(0) @map("risk_count")
  milestone String?
  tasks     String?
  templateId String? @map("template_id")
  plannedOpenDate   String  @map("planned_open_date")
  actualOpenDate    String? @map("actual_open_date")
  dispatchStatus    String? @map("dispatch_status")
  executionStatus   String? @map("execution_status")
  acceptanceStatus  String? @map("acceptance_status")
  settlementStatus  String? @map("settlement_status")
  pendingDispatchCount    Int @default(0) @map("pending_dispatch_count")
  pendingExecutionCount   Int @default(0) @map("pending_execution_count")
  pendingAcceptanceCount  Int @default(0) @map("pending_acceptance_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  phases      ProjectPhase[]
  milestones  ProjectMilestone[]
  taskTree    ProjectTask[]
  risks       ProjectRisk[]
  members     ProjectMember[]
  statusLogs  ProjectStatusLog[]
  workPackages WorkPackage[]

  @@map("projects")
}

// ─── 项目阶段表 ────────────────────────────────────────────────
model ProjectPhase {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  name      String
  startDate String   @map("start_date")
  endDate   String   @map("end_date")
  progress  Int      @default(0)
  status    String

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_phases")
}

// ─── 项目里程碑表 ──────────────────────────────────────────────
model ProjectMilestone {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  name          String
  dueDate       String   @map("due_date")
  status        String
  assignee      String?
  completedDate String?  @map("completed_date")

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_milestones")
}

// ─── 工作包表（Phase 2 新增，成本归集单元）─────────────────────
model WorkPackage {
  id              Int      @id @default(autoincrement())
  projectId       Int      @map("project_id")
  code            String   @unique
  name            String
  status          String   @default("规划中") // 规划中 | 执行中 | 已完成 | 已暂停
  managerId       String?  @map("manager_id")
  stageId         String?  @map("stage_id")
  description     String?
  progress        Int      @default(0)
  plannedStartAt  String?  @map("planned_start_at")
  plannedEndAt    String?  @map("planned_end_at")
  actualStartAt   String?  @map("actual_start_at")
  actualEndAt     String?  @map("actual_end_at")
  plannedWorkHours Int?    @map("planned_work_hours")
  actualWorkHours  Int?    @map("actual_work_hours")
  budget          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks           ProjectTask[]

  @@map("work_packages")
}

// ─── 任务表（对齐 PRD 58 字段，P0 字段优先）───────────────────
// P0: id, code, name, projectId, status, assigneeId, plannedStartAt, plannedEndAt, createdBy, createdAt
model ProjectTask {
  id              Int      @id @default(autoincrement())
  projectId       Int      @map("project_id")
  code            String   @unique
  name            String
  status          String   @default("草稿")
  assigneeId      String?  @map("assignee_id")
  assigneeName    String?  @map("assignee_name")
  startDate       DateTime?  @map("start_date")
  dueDate         DateTime?  @map("due_date")

  // ── 树形结构（P0） ──
  parentId        Int?     @map("parent_id")
  nodeLevelType   String?  @map("node_level_type")  // project_root | work_package | task
  treeLevel       Int?     @map("tree_level")
  treePath        String?  @map("tree_path")

  // ── P1 业务属性 ──
  priority        String   @default("medium")
  progress        Int      @default(0)
  taskType        String?  @map("task_type")
  sourceType      String?  @map("source_type")   // manual | template | agent | derived
  riskLevel       String?  @map("risk_level")
  slaStatus       String?  @map("sla_status")
  description     String?
  requiredFlag    Boolean  @default(true)  @map("required_flag")
  milestoneFlag   Boolean  @default(false) @map("milestone_flag")
  ownerRole       String?  @map("owner_role")
  assigneeType    String?  @map("assignee_type") // internal | vendor
  brandId         String?  @map("brand_id")
  storeId         String?  @map("store_id")

  // ── P2 执行与SLA ──
  actualStartAt  DateTime?  @map("actual_start_date")
  actualEndAt    DateTime?  @map("actual_end_date")
  blockedReason    String?  @map("blocked_reason")
  remindCount      Int      @default(0) @map("remind_count")
  tags             String?  // JSON array
  workPackageId    String?  @map("work_package_id")
  slaRuleId        String?  @map("sla_rule_id")
  plannedWorkHours Int?     @map("planned_work_hours")
  actualWorkHours  Int?     @map("actual_work_hours")

  // ── P2 标准合规 ──
  standardSnapshotId String? @map("standard_snapshot_id")
  standardBindingStatus String @default("unbound") @map("standard_binding_status") // bound | unbound
  snapshotStatus    String   @default("draft") @map("snapshot_status") // draft | bound | expired

  // ── P2 派生与整改 ──
  derivedFromTaskId Int?    @map("derived_from_task_id")
  isRectification   Boolean @default(false) @map("is_rectification")
  rectificationReason String? @map("rectification_reason")
  closeReason       String?  @map("close_reason")
  reopenCount       Int      @default(0) @map("reopen_count")

  // ── 审计字段（P0） ──
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedBy       String?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // ── 关联 ──
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask      ProjectTask?  @relation("TaskTree", fields: [parentId], references: [id])
  childTasks      ProjectTask[] @relation("TaskTree")
  derivedFrom     ProjectTask?  @relation("DerivedTask", fields: [derivedFromTaskId], references: [id])
  derivedTasks    ProjectTask[] @relation("DerivedTask")
  taskRelationsFrom TaskRelation[] @relation("TaskFrom")
  taskRelationsTo   TaskRelation[] @relation("TaskTo")
  eventLogs       TaskEventLog[]
  submissions     TaskSubmission[]
  checklist       ChecklistItem[]
  workPackage     WorkPackage? @relation(fields: [workPackageId], references: [code])

  @@map("project_tasks")
}

// ─── 任务事件日志表（审计追踪）──────────────────────────────────
model TaskEventLog {
  id            Int      @id @default(autoincrement())
  taskId        Int      @map("task_id")
  eventType     String   @map("event_type")   // status_change | field_change | comment | attachment | assign | favorite
  eventAction   String   @map("event_action")
  beforeValue   String?  @map("before_value") // JSON
  afterValue    String?  @map("after_value")  // JSON
  operatorId    String   @map("operator_id")
  operatorSource String  @default("user") @map("operator_source") // user | agent | system
  createdAt     DateTime @default(now()) @map("created_at")

  task          ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([eventType])
  @@map("task_event_logs")
}

// ─── 任务提交记录表（成果提交与验收）───────────────────────────
model TaskSubmission {
  id              Int      @id @default(autoincrement())
  taskId          Int      @map("task_id")
  submissionType  String   @default("normal") @map("submission_type") // normal | rectification | supplement
  description     String?
  attachmentIds   String?  @map("attachment_ids") // JSON: string[]
  status          String   @default("submitted")  // submitted | rejected | accepted
  submittedBy     String   @map("submitted_by")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  reviewedBy      String?  @map("reviewed_by")
  reviewResult    String?  @map("review_result")  // pass | reject
  reviewComment   String?  @map("review_comment")
  reviewedAt      DateTime? @map("reviewed_at")

  task            ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([status])
  @@map("task_submissions")
}

// ─── 任务关联表（前置依赖） ────────────────────────────────────
model TaskRelation {
  id           Int      @id @default(autoincrement())
  fromTaskId   Int      @map("from_task_id")
  toTaskId     Int      @map("to_task_id")
  relationType String   @map("relation_type") // finish_start | start_start | finish_finish | start_finish

  fromTask     ProjectTask @relation("TaskFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask       ProjectTask @relation("TaskTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@unique([fromTaskId, toTaskId, relationType])
  @@map("task_relations")
}

// ─── 任务检查项表（P2-T1 独立实体） ────────────────────────────
model ChecklistItem {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  label     String
  done      Boolean  @default(false)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  task      ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("checklist_items")
}

// ─── 项目风险表 ────────────────────────────────────────────────
model ProjectRisk {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  description String
  level       String
  probability String?
  impact      String?
  mitigation  String?
  status      String
  assignee    String?
  dueDate     String?  @map("due_date")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_risks")
}

// ─── 项目成员表 ────────────────────────────────────────────────
model ProjectMember {
  id         Int     @id @default(autoincrement())
  projectId  Int     @map("project_id")
  userId     String  @map("user_id")
  name       String
  role       String
  avatar     String?
  department String?
  phone      String?
  email      String?

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_members")
}

// ─── 项目状态流转日志表 ────────────────────────────────────────
model ProjectStatusLog {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  type      String   // 'transition' | 'hook'
  at        DateTime
  operator  String
  message   String
  fromStatus String? @map("from_status")
  toStatus   String? @map("to_status")
  reason    String?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_status_logs")
}

// ─── 项目模板表（标准管理 Phase A/B）────────────────────────────
model ProjectTemplate {
  id                  Int      @id @default(autoincrement())
  templateId          String   @unique @map("template_id")
  templateCode        String   @unique @map("template_code")
  templateName        String   @map("template_name")
  templateVersion     String   @map("template_version")
  status              String   // "draft" | "reviewing" | "ready" | "active" | "inactive" | "deprecated"
  priority            Int      @default(0)
  scopes              String?  // JSON: TemplateScopes (brandScope, storeTypeScope, regionScope, projectTypeScope, serviceScope)
  phaseBlueprint      String?  // JSON: PhaseBlueprint[]
  milestoneBlueprint  String?  // JSON: MilestoneBlueprint[]
  taskTemplateBinding String?  // JSON: ProjectTemplateBinding[] (引用的任务模板ID列表)
  meta                String?  // JSON: TemplateMeta (createdBy, updatedBy, effectiveFrom, effectiveTo)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("project_templates")
}

// ─── 任务模板表（标准管理 Phase A）───────────────────────────────
model TaskTemplate {
  id                  Int      @id @default(autoincrement())
  taskTemplateId      String   @unique @map("task_template_id")
  taskTemplateCode    String   @unique @map("task_template_code")
  taskTemplateName    String   @map("task_template_name")
  taskTemplateVersion String   @map("task_template_version")
  status              String   // "draft" | "reviewing" | "ready" | "active" | "inactive" | "deprecated"
  templateLevel       String   @map("template_level") // "project_root" | "stage" | "work_package" | "task"
  businessDomain      String   @map("business_domain")
  taskType            String   @map("task_type")
  requiredFlag        Boolean  @default(false) @map("required_flag")
  milestoneFlag       Boolean  @default(false) @map("milestone_flag")
  ownerRole           String   @map("owner_role")
  assigneeTypeDefault String   @map("assignee_type_default")
  slaRuleId           String?  @map("sla_rule_id")
  standardBinding     String?  // JSON: StandardBinding (defaultStandardPackageId, executionStandardIds, acceptanceStandardIds, checklistTemplateIds)
  dependencyBlueprint String?  // JSON: DependencyBlueprint[] (fromTemplateCode, toTemplateCode, relationType, constraintType, lagDays)
  childTemplateRefs   String?  // JSON: TaskTemplateChildRef[]
  parentTemplateCode  String?  @map("parent_template_code")
  sortOrder           Int      @default(0) @map("sort_order")
  meta                String?  // JSON: TemplateMeta
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("task_templates")
}

// ─── 人员主表（阶段 A - 人员最小底座）───────────────────────────
model Person {
  id                 Int      @id @default(autoincrement())
  personCode         String   @map("person_code")
  name               String
  mobile             String
  email              String?
  avatarUrl          String?  @map("avatar_url")
  orgId              Int      @map("org_id")
  title              String?
  employmentType     Int      @default(1) @map("employment_type") // 1内部 2外包 3供应商
  personStatus       Int      @default(1) @map("person_status")   // 1在岗 2请假 3离岗 4禁用
  availabilityStatus Int      @default(1) @map("availability_status") // 1可分配 2忙碌 3不可分配
  workCity           String?  @map("work_city")
  currentTaskCount   Int      @default(0) @map("current_task_count")
  criticalTaskCount  Int      @default(0) @map("critical_task_count")
  riskLevel          Int      @default(1) @map("risk_level")
  remark             String?
  isDeleted          Boolean  @default(false) @map("is_deleted")
  deletedAt          DateTime? @map("deleted_at")
  createdBy          String   @default("system") @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedBy          String?  @map("updated_by")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization       Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, mobile])
  @@unique([personCode])
  @@index([orgId, personStatus, availabilityStatus])
  @@index([orgId, personStatus])
  @@map("pm_person")
}

// ─── 组织表（阶段 A - 人员最小底座）─────────────────────────────
model Organization {
  id            Int      @id @default(autoincrement())
  orgCode       String   @unique @map("org_code")
  orgName       String   @map("org_name")
  orgType       Int      @default(1) @map("org_type") // 1品牌方 2平台 3资源方
  status        Int      @default(1)                    // 1启用 2禁用
  contactName   String?  @map("contact_name")
  contactMobile String?  @map("contact_mobile")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  persons       Person[]

  @@map("pm_organization")
}

// ─── 供应商表（采购管理）────────────────────────────────────────
model Supplier {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  name                String
  category            String
  status              String   // "合作中" | "待审核" | "已暂停" | "已过期"
  rating              String   // 如 "4.8"
  contact             String
  city                String
  currentTaskCount    Int      @default(0) @map("current_task_count")
  availabilityStatus  String   @map("availability_status") // "assignable" | "busy" | "unavailable"
  qualificationStatus String   @map("qualification_status") // "齐全" | "临期" | "需补齐"
  serviceAreas        String?  // JSON: string[] 服务区域
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ─── 商品类目表（采购管理，树形结构）───────────────────────────
model ProductCategory {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  parentId    Int?     @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  supplierIds String?  // JSON: string[] 关联的供应商ID
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")

  @@map("product_categories")
}

// ─── 模板实例化记录表（跟踪项目从模板创建的历史）─────────────
model TemplateInstantiation {
  id              Int      @id @default(autoincrement())
  projectId       Int      @map("project_id")
  templateId      String   @map("template_id")
  templateVersion String   @map("template_version")
  matchInput      String?  // JSON: 实例化输入
  outputSnapshot  String?  // JSON: 实例化输出快照
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String   @map("created_by")

  @@map("template_instantiations")
}
