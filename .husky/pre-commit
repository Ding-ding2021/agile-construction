#!/bin/bash
echo "🔍 提交前检查..."

# 1. lint-staged：只对暂存区文件跑 ESLint + Prettier
npx lint-staged || exit 1

# 2. TypeScript 类型检查（不生成文件）
echo "📝 检查 TypeScript 类型..."
npx tsc --noEmit || exit 1

# 3. 检查分支名格式（阻断式）
BRANCH_NAME=$(git symbolic-ref --short HEAD 2>/dev/null)
echo "📝 检查分支名..."

# main 和 master 免检
if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
  echo "✅ 分支名检查通过（$BRANCH_NAME）"
else
  # 中文检测（macOS 兼容）
  if echo "$BRANCH_NAME" | python3 -c "import sys; t=sys.stdin.read(); exit(0 if any('\u4e00' <= c <= '\u9fff' for c in t) else 1)" 2>/dev/null; then
    echo "❌ 分支名包含中文字符，禁止提交。请使用英文命名：feat/<描述>"
    exit 1
  fi

  if ! echo "$BRANCH_NAME" | grep -qE "^(feat|fix|docs|refactor|chore|test|hotfix)/"; then
    echo "❌ 分支名不符合规范：$BRANCH_NAME"
    echo "   允许格式：feat/<描述> | fix/<描述> | docs/<描述> | refactor/<描述> | chore/<描述> | test/<描述> | hotfix/<描述>"
    echo "   或直接使用 main 分支"
    exit 1
  fi

  echo "✅ 分支名检查通过"
fi

# 4. 记忆日志格式校验（警告模式，不阻断）
echo "📝 检查记忆日志格式..."
MEMORY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^memory/.*\.md$' || true)
if [ -n "$MEMORY_FILES" ]; then
  while IFS= read -r f; do
    if [ -f "$f" ] && grep -q '避坑' "$f"; then
      HAS_TABLE=$(grep -c '| 避坑 |' "$f" || echo 0)
      HAS_FALLBACK=$(grep -cE '避坑[：:]\s*[0-9]+\s*次' "$f" || echo 0)
      if [ "${HAS_TABLE:-0}" -eq 0 ] && [ "${HAS_FALLBACK:-0}" -eq 0 ]; then
        echo "⚠️  $f: 避坑格式可能不规范，建议使用标准格式"
        echo "   标准格式1: | 避坑 | 英文思考 3次 / 跳skill 2次 |"
        echo "   标准格式2: 避坑：3次（E1 英文思考 / E2 跳skill）"
      fi
    fi
  done <<< "$MEMORY_FILES"
fi

echo "✅ 检查通过"
