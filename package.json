{
  "name": "agile-construction",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "src-next"
  ],
  "scripts": {
    "dev": "npm run dev -w src-next",
    "dev:legacy": "vite --port 5174",
    "dev:local": "concurrently \"npm run local-api\" \"npm run dev\"",
    "local-api": "tsx local-api/server.ts",
    "build": "npm run build -w src-next",
    "build:legacy": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:seed": "tsx prisma/seed.ts",
    "prepare": "husky",
    "ladle": "npm run ladle -w src-next",
    "ladle:build": "npm run ladle:build -w src-next",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@mui/x-tree-view": "^9.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^7.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.4"
  }
}
